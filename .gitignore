# ── Personal Financial Data — NEVER COMMIT ────────────────────────────────────

# SQLite database (your actual transaction data)
finance.db
finance.db-shm
finance.db-wal

# Bank statement PDFs and CSVs you drop in — keep the folder placeholder
data/statements/*
!data/statements/.gitkeep

# Your personal financial profile — fill this in locally only
# Use profile.example.txt as the committed blank template
profile.txt


# ── Personal Financial Data — NEVER COMMIT ────────────────────────────────────
# Rule: anything with real names, amounts, account numbers, or personal
# spending patterns stays local. If in doubt, add it here.

# SQLite database — your actual transaction data
finance.db
finance.db-shm
finance.db-wal

# Entire data/ folder — statements, corrections.json, any personal JSON
data/

# Your personal financial profile (use profile.example.txt as the committed template)
profile.txt

# External accounts snapshot — EQ Bank, GICs, TFSA balances (use financial_snapshot.example.json as template)
financial_snapshot.json

# Bills — real personal amounts and due dates
bills.local.json
*.local.json        # catch-all for any future *.local.json config files

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env
frontend/.env.local

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Google Cloud Credentials — NEVER COMMIT ───────────────────────────────────
# Service account key — grants read access to your Google Sheets
google_credentials.json
*_credentials.json

# ── Local config overrides — NEVER COMMIT ─────────────────────────────────────
# Personal values like Google Sheet ID live here, not in config.py
config_local.py

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
.env
.env.local

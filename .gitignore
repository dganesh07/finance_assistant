# ── Personal Financial Data — NEVER COMMIT ────────────────────────────────────

# SQLite database (your actual transaction data)
finance.db
finance.db-shm
finance.db-wal

# Bank statement PDFs and CSVs — keep the folder placeholder only
data/statements/*
!data/statements/.gitkeep

# Your personal financial profile — fill in locally, use profile.example.txt as template
profile.txt

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env
frontend/.env.local

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
.env
.env.local
